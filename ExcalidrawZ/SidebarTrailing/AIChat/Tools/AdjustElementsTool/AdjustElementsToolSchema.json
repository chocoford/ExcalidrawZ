{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AdjustElementsToolInput",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "1"
    },
    "dryRun": {
      "type": "boolean",
      "default": false
    },
    "ops": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/operation"
      }
    }
  },
  "required": [
    "ops"
  ],
  "definitions": {
    "operation": {
      "oneOf": [
        { "$ref": "#/definitions/addOp" },
        { "$ref": "#/definitions/updateOp" },
        { "$ref": "#/definitions/moveOp" },
        { "$ref": "#/definitions/resizeOp" },
        { "$ref": "#/definitions/deleteOp" },
        { "$ref": "#/definitions/wrapOp" }
      ]
    },
    "addOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "add" },
        "element": { "$ref": "#/definitions/elementSkeleton" },
        "place": { "$ref": "#/definitions/placeHint" }
      },
      "required": [
        "op",
        "element"
      ]
    },
    "updateOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "update" },
        "id": { "type": "string" },
        "patch": { "$ref": "#/definitions/elementPatch" }
      },
      "required": [
        "op",
        "id",
        "patch"
      ]
    },
    "moveOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "move" },
        "id": { "type": "string" },
        "dx": { "type": "number" },
        "dy": { "type": "number" }
      },
      "required": [
        "op",
        "id",
        "dx",
        "dy"
      ]
    },
    "resizeOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "resize" },
        "id": { "type": "string" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 },
        "dw": { "type": "number" },
        "dh": { "type": "number" },
        "anchor": {
          "type": "string",
          "enum": [
            "center",
            "topLeft",
            "topRight",
            "bottomLeft",
            "bottomRight"
          ]
        }
      },
      "required": [
        "op",
        "id"
      ],
      "anyOf": [
        { "required": [ "width" ] },
        { "required": [ "height" ] },
        { "required": [ "dw" ] },
        { "required": [ "dh" ] }
      ]
    },
    "deleteOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "delete" },
        "id": { "type": "string" }
      },
      "required": [
        "op",
        "id"
      ]
    },
    "wrapOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "wrap" },
        "targetIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "IDs of existing elements to wrap. The app computes their union bounding box."
        },
        "shape": {
          "type": "string",
          "enum": [
            "rectangle",
            "ellipse",
            "diamond"
          ],
          "default": "rectangle",
          "description": "Shape used as the wrapper."
        },
        "padding": {
          "type": "number",
          "minimum": 0,
          "default": 24,
          "description": "Canvas units added around the union bounds of the target elements."
        },
        "stylePreset": {
          "type": "string",
          "enum": [
            "default",
            "accent",
            "note"
          ],
          "description": "Pre-baked wrapper style. `style` overrides individual fields."
        },
        "style": { "$ref": "#/definitions/stylePatch" },
        "label": {
          "type": "string",
          "description": "Optional text label added with the wrapper."
        },
        "labelPosition": {
          "type": "string",
          "enum": [
            "insideTopLeft",
            "above"
          ],
          "default": "insideTopLeft"
        }
      },
      "required": [
        "op",
        "targetIds"
      ]
    },
    "elementSkeleton": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "rectangle",
            "ellipse",
            "diamond",
            "text",
            "line",
            "arrow"
          ],
          "description": "Element family. rectangle/ellipse/diamond use width/height. text uses text/label and font sizing. line/arrow use endX+endY OR (arrow only) fromId+toId for binding."
        },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 },
        "endX": {
          "type": "number",
          "description": "line/arrow only — absolute x coordinate of the end point. Ignored when fromId+toId are present."
        },
        "endY": {
          "type": "number",
          "description": "line/arrow only — absolute y coordinate of the end point."
        },
        "fromId": {
          "type": "string",
          "description": "arrow only — bind start to this element (centered, edge-orbit)."
        },
        "toId": {
          "type": "string",
          "description": "arrow only — bind end to this element (centered, edge-orbit)."
        },
        "arrowhead": {
          "type": "string",
          "enum": ["arrow", "triangle", "triangle_outline", "diamond", "diamond_outline", "dot", "circle", "circle_outline", "bar"],
          "description": "arrow only — end arrowhead style. Default: arrow."
        },
        "elbowed": {
          "type": "boolean",
          "description": "arrow only — use right-angle (elbow) routing. Default: false."
        },
        "containerId": {
          "type": "string",
          "description": "text only — bind this text inside an existing rectangle/ellipse/diamond as its label. Position is auto-centered inside the container."
        },
        "text": { "type": "string" },
        "label": { "type": "string" },
        "stylePreset": {
          "type": "string",
          "enum": [
            "default",
            "accent",
            "note"
          ],
          "description": "Pre-baked color/stroke combo. `default` = black on transparent. `accent` = blue on light blue. `note` = brown on cream. Use for quick consistent looks; for arbitrary colors use `style` (which overrides preset values)."
        },
        "style": { "$ref": "#/definitions/stylePatch" }
      },
      "required": [
        "type"
      ]
    },
    "placeHint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relativeToId": { "type": "string" },
        "position": {
          "type": "string",
          "enum": [
            "right",
            "left",
            "above",
            "below",
            "center",
            "inside"
          ]
        },
        "gap": { "type": "number", "minimum": 0 }
      },
      "required": [
        "relativeToId",
        "position"
      ]
    },
    "elementPatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "text": { "type": "string" },
        "label": { "type": "string" },
        "bounds": { "$ref": "#/definitions/boundsPatch" },
        "stylePreset": {
          "type": "string",
          "enum": [
            "default",
            "accent",
            "note"
          ],
          "description": "Pre-baked color/stroke combo applied as a baseline. `style` overrides individual fields."
        },
        "style": { "$ref": "#/definitions/stylePatch" },
        "containerId": {
          "type": ["string", "null"],
          "description": "text only — bind to / unbind from a container shape. null detaches."
        }
      }
    },
    "boundsPatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 }
      }
    },
    "stylePatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "Per-field style overrides. Layered on top of `stylePreset` if both are supplied — fields here win. Omit fields you don't want to touch (on update ops, omitted fields keep their existing value).",
      "properties": {
        "strokeColor": {
          "type": "string",
          "description": "Stroke / outline / text color. Hex (`#1e1e1e`) or `transparent`. Excalidraw default palette stroke values: `#1e1e1e` (black), `#e03131` (red), `#2f9e44` (green), `#1971c2` (blue), `#f08c00` (orange), `#9c36b5` (purple). Other hex values render fine — the palette is just a suggestion."
        },
        "backgroundColor": {
          "type": "string",
          "description": "Fill color for shape interiors. Hex or `transparent`. Default palette fills: `transparent`, `#ffc9c9` (light red), `#b2f2bb` (light green), `#a5d8ff` (light blue), `#ffec99` (light yellow), `#eebefa` (light purple). Text elements ignore this."
        },
        "strokeWidth": {
          "type": "number",
          "description": "Line thickness in px. Excalidraw thin=1, regular=2, bold=4. Other values are accepted but the toolbar shows only those three."
        },
        "roughness": {
          "type": "number",
          "enum": [0, 1, 2],
          "description": "Hand-drawn jitter level. 0 = architect (clean), 1 = artist (default), 2 = cartoonist (loose)."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Element opacity in 0–100 (NOT 0–1). 100 = fully opaque."
        },
        "fontSize": {
          "type": "number",
          "description": "text only — font size in px. Excalidraw toolbar values: 16 (S), 20 (M, default), 28 (L), 36 (XL)."
        },
        "fontFamily": {
          "type": "number",
          "description": "text only — font family id. 1 = Virgil (hand-drawn), 2 = Helvetica, 3 = Cascadia (mono), 5 = Excalifont (default)."
        },
        "textAlign": {
          "type": "string",
          "enum": ["left", "center", "right"],
          "description": "text only — horizontal alignment within the text frame."
        },
        "verticalAlign": {
          "type": "string",
          "enum": ["top", "middle", "bottom"],
          "description": "text only — vertical alignment when the text is bound to a container shape."
        }
      }
    }
  }
}
