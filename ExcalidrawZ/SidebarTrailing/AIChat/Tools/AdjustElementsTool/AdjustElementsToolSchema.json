{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AdjustElementsToolInput",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "default": "1"
    },
    "dryRun": {
      "type": "boolean",
      "default": false
    },
    "approvalReason": {
      "type": "string",
      "description": "Top-level reason for requesting user approval. Include this when an operation is risky or destructive, especially delete operations. Omit or leave empty for safe edits."
    },
    "ops": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/operation"
      }
    }
  },
  "required": [
    "ops"
  ],
  "definitions": {
    "operation": {
      "oneOf": [
        { "$ref": "#/definitions/addOp" },
        { "$ref": "#/definitions/addLabeledShapeOp" },
        { "$ref": "#/definitions/updateOp" },
        { "$ref": "#/definitions/moveOp" },
        { "$ref": "#/definitions/resizeOp" },
        { "$ref": "#/definitions/deleteOp" },
        { "$ref": "#/definitions/wrapOp" },
        { "$ref": "#/definitions/mermaidOp" },
        { "$ref": "#/definitions/connectOp" }
      ]
    },
    "addLabeledShapeOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "addLabeledShape" },
        "shape": {
          "type": "string",
          "enum": [
            "rectangle",
            "ellipse",
            "diamond"
          ],
          "default": "rectangle",
          "description": "Shape to create. The app also creates and binds centered text inside it."
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Label text rendered inside the shape."
        },
        "x": {
          "type": "number",
          "description": "Optional top-left x. If omitted, the app places the shape to the right of the existing scene."
        },
        "y": {
          "type": "number",
          "description": "Optional top-left y. If omitted, the app vertically aligns with the existing scene."
        },
        "width": {
          "type": "number",
          "minimum": 1,
          "description": "Optional shape width. If omitted, the app sizes from the label text."
        },
        "height": {
          "type": "number",
          "minimum": 1,
          "description": "Optional shape height. If omitted, the app sizes from the label text."
        },
        "stylePreset": {
          "type": "string",
          "enum": [
            "default",
            "accent",
            "note"
          ],
          "description": "Pre-baked shape/text style. `style` overrides individual fields."
        },
        "style": { "$ref": "#/definitions/stylePatch" }
      },
      "required": [
        "op",
        "shape",
        "text"
      ]
    },
    "addOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "add" },
        "elements": {
          "description": "Canonical Excalidraw skeleton objects passed together to one insertFromSkeleton call. Include a temporary id on each skeleton entry, including text, frames, images, and arrows. Element order controls z-order: earlier skeletons are behind later skeletons, so put background rectangles/frames/lanes first and standalone foreground text/annotations last. If the add op has layout, skeletons without x/y are placed by the layout engine; skeletons with both x and y are pinned. If the add op does not have layout, every placed non-arrow skeleton must include both x and y; bound arrows still use start.id and end.id only. connect handles existing elements or cross-batch links. Bound arrows support both directed and undirected relationships; set arrowheads to null for visually headless connectors. If fontFamily is included, 5 is the app default; 4 is invalid. Do not include unsupported CSS-style text fields such as fontWeight. For centered standalone text, include an explicit width; textAlign alone does not center auto-width text."
        },
        "layout": {
          "type": "string",
          "description": "Optional insertFromSkeleton layout engine. Common values: layered, mrtree, radial, force, stress, box, rectpacking. When present, x+y pins a skeleton; missing coordinates are generated by the layout engine. Omit layout only when manually providing x and y for every placed non-arrow skeleton."
        },
        "layoutOptions": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" }
            ]
          },
          "description": "Optional ELK/layout options forwarded to insertFromSkeleton, keyed by layout option name."
        },
        "place": { "$ref": "#/definitions/placeHint" },
        "regenerateIds": {
          "type": "boolean",
          "description": "Forwarded to insertFromSkeleton."
        },
        "position": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "auto",
                "viewport-center",
                "scene-center"
              ]
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "anchor": {
                  "type": "string",
                  "enum": [
                    "top-left",
                    "center"
                  ],
                  "default": "top-left"
                }
              },
              "required": [
                "x",
                "y"
              ]
            }
          ],
          "description": "Controls where the already-laid-out group enters the scene. This is not for internal element layout. Takes precedence over `place`."
        },
        "focus": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "animate": { "type": "boolean" },
                "duration": {
                  "type": "integer",
                  "minimum": 0
                },
                "viewportZoomFactor": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          ]
        },
        "files": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional files map forwarded to insertFromSkeleton."
        },
        "captureUpdate": {
          "type": "string",
          "enum": [
            "IMMEDIATELY",
            "EVENTUALLY",
            "NEVER"
          ]
        },
        "sanitize": {
          "type": "boolean",
          "description": "Forwarded to insertFromSkeleton."
        }
      },
      "required": [
        "op",
        "elements"
      ]
    },
    "updateOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "update" },
        "id": { "type": "string" },
        "patch": { "$ref": "#/definitions/elementPatch" }
      },
      "required": [
        "op",
        "id",
        "patch"
      ]
    },
    "moveOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "move" },
        "id": { "type": "string" },
        "dx": { "type": "number" },
        "dy": { "type": "number" }
      },
      "required": [
        "op",
        "id",
        "dx",
        "dy"
      ]
    },
    "resizeOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "resize" },
        "id": { "type": "string" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 },
        "dw": { "type": "number" },
        "dh": { "type": "number" },
        "anchor": {
          "type": "string",
          "enum": [
            "center",
            "topLeft",
            "topRight",
            "bottomLeft",
            "bottomRight"
          ]
        }
      },
      "required": [
        "op",
        "id"
      ],
      "anyOf": [
        { "required": [ "width" ] },
        { "required": [ "height" ] },
        { "required": [ "dw" ] },
        { "required": [ "dh" ] }
      ]
    },
    "deleteOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "delete" },
        "id": { "type": "string" }
      },
      "required": [
        "op",
        "id"
      ]
    },
    "wrapOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "wrap" },
        "targetIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "IDs of existing elements to wrap. The app computes their union bounding box."
        },
        "shape": {
          "type": "string",
          "enum": [
            "rectangle",
            "ellipse",
            "diamond"
          ],
          "default": "rectangle",
          "description": "Shape used as the wrapper."
        },
        "padding": {
          "type": "number",
          "minimum": 0,
          "default": 24,
          "description": "Canvas units added around the union bounds of the target elements."
        },
        "stylePreset": {
          "type": "string",
          "enum": [
            "default",
            "accent",
            "note"
          ],
          "description": "Pre-baked wrapper style. `style` overrides individual fields."
        },
        "style": { "$ref": "#/definitions/stylePatch" },
        "label": {
          "type": "string",
          "description": "Optional text label added with the wrapper."
        },
        "labelPosition": {
          "type": "string",
          "enum": [
            "insideTopLeft",
            "above"
          ],
          "default": "insideTopLeft"
        }
      },
      "required": [
        "op",
        "targetIds"
      ]
    },
    "mermaidOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "mermaid" },
        "definition": {
          "type": "string",
          "minLength": 1,
          "description": "Mermaid source definition. Native editable Excalidraw conversion is supported for these Mermaid forms: flowchart/graph, sequenceDiagram, stateDiagram, classDiagram, and erDiagram. Other Mermaid chart types may not remain native editable Excalidraw elements."
        },
        "position": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "auto",
                "viewport-center",
                "scene-center"
              ]
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "anchor": {
                  "type": "string",
                  "enum": [
                    "top-left",
                    "center"
                  ],
                  "default": "top-left"
                }
              },
              "required": [
                "x",
                "y"
              ]
            }
          ],
          "default": "auto",
          "description": "`auto` places the converted diagram to the right of the existing scene. `viewport-center` and `scene-center` perform explicit centering; object form accepts x/y."
        },
        "focus": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "animate": { "type": "boolean" },
                "duration": {
                  "type": "integer",
                  "minimum": 0
                },
                "viewportZoomFactor": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          ],
          "default": false,
          "description": "Whether to focus the inserted Mermaid elements after insertion. true uses WebView defaults; object customizes animation."
        },
        "regenerateIds": {
          "type": "boolean",
          "default": true,
          "description": "Assign fresh Excalidraw IDs to converted elements to avoid collisions."
        },
        "mermaidConfig": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional config forwarded to Mermaid. Common fields: startOnLoad, flowchart.curve, themeVariables.fontSize, maxEdges, maxTextSize."
        },
        "captureUpdate": {
          "type": "string",
          "enum": [
            "IMMEDIATELY",
            "EVENTUALLY",
            "NEVER"
          ],
          "default": "IMMEDIATELY"
        }
      },
      "required": [
        "op",
        "definition"
      ]
    },
    "connectOp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "const": "connect" },
        "from": {
          "type": "string",
          "minLength": 1,
          "description": "Existing source element id from read_file."
        },
        "to": {
          "type": "string",
          "minLength": 1,
          "description": "Existing target element id from read_file."
        },
        "arrow": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional arrow styling and label. Geometry is computed by Excalidraw; do not calculate edge coordinates. For undirected relationships, set startArrowhead and endArrowhead to null.",
          "properties": {
            "strokeColor": { "type": "string" },
            "strokeWidth": { "type": "number" },
            "strokeStyle": {
              "type": "string",
              "enum": ["solid", "dashed", "dotted"]
            },
            "roughness": { "type": "number" },
            "opacity": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "startArrowhead": {
              "type": ["string", "null"],
              "description": "Optional start arrowhead. Common values: arrow, bar, dot, triangle, diamond, or null."
            },
            "endArrowhead": {
              "type": ["string", "null"],
              "description": "Optional end arrowhead. Common values: arrow, bar, dot, triangle, diamond, or null."
            },
            "elbowed": { "type": "boolean" },
            "label": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "text": { "type": "string", "minLength": 1 },
                    "fontSize": { "type": "number" },
                    "fontFamily": {
                      "type": "number",
                      "description": "Font family id. 5 is the app default. 4 is invalid."
                    },
                    "strokeColor": { "type": "string" }
                  },
                  "required": ["text"]
                }
              ]
            },
            "fixedPoint": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "start": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "items": { "type": "number" }
                },
                "end": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "items": { "type": "number" }
                }
              }
            },
            "mode": {
              "type": "string",
              "enum": ["inside", "orbit", "skip"]
            }
          }
        },
        "captureUpdate": {
          "type": "string",
          "enum": [
            "IMMEDIATELY",
            "EVENTUALLY",
            "NEVER"
          ],
          "default": "IMMEDIATELY"
        }
      },
      "required": [
        "op",
        "from",
        "to"
      ]
    },
    "placeHint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relativeToId": { "type": "string" },
        "position": {
          "type": "string",
          "enum": [
            "right",
            "left",
            "above",
            "below",
            "center",
            "inside"
          ]
        },
        "gap": { "type": "number", "minimum": 0 }
      },
      "required": [
        "relativeToId",
        "position"
      ]
    },
    "elementPatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "text": { "type": "string" },
        "label": { "type": "string" },
        "bounds": { "$ref": "#/definitions/boundsPatch" },
        "stylePreset": {
          "type": "string",
          "enum": [
            "default",
            "accent",
            "note"
          ],
          "description": "Pre-baked color/stroke combo applied as a baseline. `style` overrides individual fields."
        },
        "style": { "$ref": "#/definitions/stylePatch" },
        "containerId": {
          "type": ["string", "null"],
          "description": "text only — bind to / unbind from a container shape. null detaches."
        }
      }
    },
    "boundsPatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 }
      }
    },
    "stylePatch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "Per-field style overrides. Layered on top of `stylePreset` if both are supplied — fields here win. Omit fields you don't want to touch (on update ops, omitted fields keep their existing value).",
      "properties": {
        "strokeColor": {
          "type": "string",
          "description": "Stroke / outline / text color. Hex (`#1e1e1e`) or `transparent`. Excalidraw default palette stroke values: `#1e1e1e` (black), `#e03131` (red), `#2f9e44` (green), `#1971c2` (blue), `#f08c00` (orange), `#9c36b5` (purple). Other hex values render fine — the palette is just a suggestion."
        },
        "backgroundColor": {
          "type": "string",
          "description": "Fill color for shape interiors. Hex or `transparent`. Default palette fills: `transparent`, `#ffc9c9` (light red), `#b2f2bb` (light green), `#a5d8ff` (light blue), `#ffec99` (light yellow), `#eebefa` (light purple). Text elements ignore this."
        },
        "strokeWidth": {
          "type": "number",
          "description": "Line thickness in px. Excalidraw thin=1, regular=2, bold=4. Other values are accepted but the toolbar shows only those three."
        },
        "roughness": {
          "type": "number",
          "enum": [0, 1, 2],
          "description": "Hand-drawn jitter level. 0 = architect (clean), 1 = artist (default), 2 = cartoonist (loose)."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Element opacity in 0–100 (NOT 0–1). 100 = fully opaque."
        },
        "fontSize": {
          "type": "number",
          "description": "text only — font size in px. Excalidraw toolbar values: 16 (S), 20 (M, default), 28 (L), 36 (XL)."
        },
        "fontFamily": {
          "type": "number",
          "description": "text only — font family id. 1 = Virgil (hand-drawn), 2 = Helvetica, 3 = Cascadia (mono), 4 = legacy/unused invalid value, 5 = Excalifont / app default."
        },
        "textAlign": {
          "type": "string",
          "enum": ["left", "center", "right"],
          "description": "text only — horizontal alignment within the text frame. For standalone text, provide an explicit width when using center/right alignment; auto-width text is anchored at x/y."
        },
        "verticalAlign": {
          "type": "string",
          "enum": ["top", "middle", "bottom"],
          "description": "text only — vertical alignment when the text is bound to a container shape."
        }
      }
    }
  }
}
